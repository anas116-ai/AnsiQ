# ================================================================
# AnsiQ - Production Environment Configuration
# ================================================================
# Copy this to .env and fill in your values:

# -- General --
ANSIQ_ENV=production
ANSIQ_DEBUG=false
ANSIQ_LOG_LEVEL=INFO
ANSIQ_SECRET_KEY=generate-a-random-64-char-string-here
ANSIQ_JWT_SECRET=generate-a-random-64-char-string-here
ANSIQ_CORS_ORIGINS=https://app.ansiq.ai,https://dashboard.ansiq.ai

# -- PostgreSQL --
ANSIQ_DB_HOST=localhost
ANSIQ_DB_PORT=5432
ANSIQ_DB_NAME=ansiq
ANSIQ_DB_USER=ansiq
ANSIQ_DB_PASSWORD=strong-database-password-here
ANSIQ_DB_POOL_SIZE=20
ANSIQ_DB_MAX_OVERFLOW=10

# -- Redis --
ANSIQ_REDIS_HOST=localhost
ANSIQ_REDIS_PORT=6379
ANSIQ_REDIS_PASSWORD=
ANSIQ_REDIS_DB=0
ANSIQ_REDIS_SSL=false

# -- Stripe Billing --
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_MONTHLY_PRICE_ID=price_monthly_xxxxxxxx
STRIPE_YEARLY_PRICE_ID=price_yearly_xxxxxxxx

# -- Email (SMTP) --
ANSIQ_EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxx
ANSIQ_FROM_EMAIL=noreply@ansiq.ai
ANSIQ_FROM_NAME=AnsiQ

# -- Sentry Error Tracking --
SENTRY_DSN=https://key@o123.ingest.us.sentry.io/123
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# -- Rate Limiting --
ANSIQ_RATE_LIMIT=100
ANSIQ_RATE_LIMIT_WINDOW=60
ANSIQ_RATE_BURST=20

# -- Grafana --
GRAFANA_PASSWORD=admin
