# ================================================================
#  AnsiQ - Production Environment Configuration
# ================================================================
# Copy this file to .env and fill in your real values.
#
#   cp .env.example .env
#
# WARNING: Never commit .env to version control! It contains secrets.
# ================================================================

# - Application ----------------------------------------------------------
ANSIQ_ENV=development
ANSIQ_DEBUG=false
ANSIQ_LOG_LEVEL=INFO
ANSIQ_SECRET_KEY=

# - Authentication & Security -------------------------------------------
ANSIQ_JWT_SECRET=
ANSIQ_JWT_EXPIRE_MINUTES=60
ANSIQ_JWT_REFRESH_EXPIRE_DAYS=30
ANSIQ_BCRYPT_ROUNDS=12
ANSIQ_CORS_ORIGINS=*
ANSIQ_RATE_LIMIT_PER_MINUTE=60
ANSIQ_RATE_LIMIT_BURST=20
ANSIQ_MFA_ISSUER=AnsiQ

# - PostgreSQL Database -------------------------------------------------
ANSIQ_DB_HOST=localhost
ANSIQ_DB_PORT=5432
ANSIQ_DB_NAME=ansiq
ANSIQ_DB_USER=ansiq
ANSIQ_DB_PASSWORD=ansiq
ANSIQ_DB_POOL_SIZE=20
ANSIQ_DB_MAX_OVERFLOW=10
ANSIQ_DB_POOL_RECYCLE=1800
ANSIQ_DB_ECHO=false

# - Redis -----------------------------------------------------------------
ANSIQ_REDIS_HOST=localhost
ANSIQ_REDIS_PORT=6379
ANSIQ_REDIS_PASSWORD=
ANSIQ_REDIS_DB=0
ANSIQ_REDIS_SSL=false

# - Stripe Billing ------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

# - Email Service -------------------------------------------------------
ANSIQ_EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ANSIQ_FROM_EMAIL=noreply@ansiq.ai
ANSIQ_FROM_NAME=AnsiQ
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# - Sentry Error Tracking -----------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# - Public URLs ---------------------------------------------------------
ANSIQ_APP_URL=http://localhost:8000
ANSIQ_API_URL=http://localhost:8000

# - API Keys (Legacy) ---------------------------------------------------
ANSIQ_API_KEYS=

# - OpenAI / LLM API Keys -----------------------------------------------
OPENAI_API_KEY=

# - Data Directory ------------------------------------------------------
ANSIQ_DATA_DIR=./data
